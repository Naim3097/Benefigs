# ============================================================================
# BENEFIGS — ENVIRONMENT VARIABLES
# Copy to `.env.local` and fill in. All are OPTIONAL for local development —
# the app degrades gracefully when a value is missing (analytics/payment simply
# stay disabled). Nothing here blocks design or build.
# ============================================================================

# --- Core -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://benefigs.com"

# --- Analytics & marketing (public IDs; safe to expose) ---------------------
NEXT_PUBLIC_GA4_ID=""                    # e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=""                    # e.g. GTM-XXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=""             # Meta (Facebook) Pixel ID
NEXT_PUBLIC_TIKTOK_PIXEL_ID=""           # TikTok Pixel ID
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""  # Search Console meta verification token

# --- Payments: Lean.X by LeanX.io (SERVER-ONLY — never expose) --------------
# Provided by client later. When LEANX_UUID is set, checkout switches from the
# safe simulated flow to the live Lean.X gateway automatically.
LEANX_UUID=""                            # <-- client will supply
LEANX_AUTH_TOKEN=""                      # API auth / secret token
LEANX_ENV="sandbox"                      # "sandbox" | "production"
LEANX_WEBHOOK_SECRET=""                  # for verifying webhook signatures
